# ============================================================
# AGRICULTURAL PRACTICES EXAMPLES
# ============================================================

agri:RicePlanting-2024-S1 a agri:Planting ;
    rdfs:label "Rice Planting Season 1 2024"@en ;
    rdfs:label "Plantation de Riz Saison 1 2024"@fr ;
    agri:practicedOn agri:Bemasoha-Rice ;
    agri:performedBy <http://example.org/farmers/Ramanate> ;
    agri:usesResource agri:Tsipory-Variety ;
    agri:hasPracticeDate "2024-10-15"^^xsd:date ;
    agri:hasDuration "P30D"^^xsd:duration ;
    .

agri:RiceHarvest-2024 a agri:Harvesting ;
    rdfs:label "Rice Harvest 2024"@en ;
    rdfs:label "Récolte de Riz 2024"@fr ;
    agri:practicedOn agri:Bemasoha-Rice ;
    agri:performedBy <http://example.org/farmers/Ramanate> ;
    agri:hasPracticeDate "2025-02-15"^^xsd:date ;
    agri:hasDuration "P14D"^^xsd:duration ;
    agri:producesOutput agri:RiceGrain-Batch-001 ;
    .

# ============================================================
# OUTPUT EXAMPLES
# ============================================================

agri:RiceGrain-Batch-001 a agri:RiceGrain ;
    rdfs:label "Rice Grain Batch 001"@en ;
