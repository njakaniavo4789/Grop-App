# ============================================================
# EXAMPLE INDIVIDUALS - agri-examples.ttl
# Demonstrating genealogical links with real examples
# ============================================================

@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix agri:  <http://example.org/agri/> .
@prefix gen:   <http://example.org/gen/> .

# ============================================================
# CROP LINEAGE EXAMPLES - Rice Varieties
# ============================================================

# ---------- Foundation Rice Varieties ----------

# Makalioka - Traditional highland variety
agri:Makalioka-Variety a agri:Rice ;
    a agri:CropVariety ;
    a gen:Cultivar ;
    rdfs:label "Makalioka Rice Variety"@en ;
    rdfs:label "Variété de Riz Makalioka"@fr ;
    skos:definition "Traditional highland rice variety from Madagascar"@en ;
    gen:hasRegistrationDate "1995-03-15"^^xsd:date ;
    gen:hasPedigreeCode "MG-RIC-001" ;
    gen:developedIn <http://sws.geonames.org/1062894/> ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    .

# Tsipory - Traditional lowland variety
agri:Tsipory-Variety a agri:Rice ;
    a agri:CropVariety ;
    a gen:Cultivar ;
    rdfs:label "Tsipory Rice Variety"@en ;
    rdfs:label "Variété de Riz Tsipory"@fr ;
    skos:definition "Traditional lowland rice variety from Madagascar"@en ;
    gen:hasRegistrationDate "1998-07-22"^^xsd:date ;
    gen:hasPedigreeCode "MG-RIC-002" ;
    gen:developedIn <http://sws.geonames.org/1062894/> ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    .

# ---------- First Generation Hybrid ----------

# Bemasoha-Rice - First generation hybrid
agri:Bemasoha-Rice a agri:Rice ;
    a agri:CropVariety ;
    a gen:Hybrid ;
    rdfs:label "Bemasoha Rice Hybrid"@en ;
    rdfs:label "Riz Hybride Bemasoha"@fr ;
    skos:definition "First generation hybrid rice variety"@en ;
    gen:hasRegistrationDate "2010-05-10"^^xsd:date ;
    gen:hasPedigreeCode "MG-RIC-HYB-001" ;
    gen:isHybridOf agri:Makalioka-Variety ;
    gen:isHybridOf agri:Tsipory-Variety ;
    gen:developedIn <http://sws.geonames.org/1062894/> ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    gen:hasGenerationNumber 1 ;
    .

# ---------- Second Generation Hybrid ----------

# Fiaramanitra-Rice - Second generation hybrid
agri:Fiaramanitra-Rice a agri:Rice ;
    a agri:CropVariety ;
    a gen:Hybrid ;
    rdfs:label "Fiaramanitra Rice Hybrid"@en ;
    rdfs:label "Riz Hybride Fiaramanitra"@fr ;
    skos:definition "Second generation hybrid rice variety with improved yield"@en ;
    gen:hasRegistrationDate "2018-03-20"^^xsd:date ;
    gen:hasPedigreeCode "MG-RIC-HYB-002" ;
    gen:isHybridOf agri:Bemasoha-Rice ;
    gen:isHybridOf agri:Tsipory-Variety ;
    gen:developedIn <http://sws.geonames.org/1062894/> ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    gen:hasGenerationNumber 2 ;
    .

# ============================================================
# MAIZE HYBRID EXAMPLES
# ============================================================

# ---------- Parent Maize Varieties ----------

agri:MaizeVarietyA a agri:Maize ;
    a agri:CropVariety ;
    a gen:Cultivar ;
    rdfs:label "Maize Variety A (Local Highland)"@en ;
    rdfs:label "Variété de Maïs A (Hautes Terres Local)"@fr ;
    skos:definition "Local highland maize cultivar"@en ;
    gen:hasRegistrationDate "2000-01-15"^^xsd:date ;
    gen:hasPedigreeCode "MG-MZ-001" ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    .

agri:MaizeVarietyB a agri:Maize ;
    a agri:CropVariety ;
    a gen:Cultivar ;
    rdfs:label "Maize Variety B (Coastal Lowland)"@en ;
    rdfs:label "Variété de Maïs B (Basses Terres Côtières)"@fr ;
    skos:definition "Coastal lowland maize cultivar"@en ;
    gen:hasRegistrationDate "2000-01-15"^^xsd:date ;
    gen:hasPedigreeCode "MG-MZ-002" ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    .

# ---------- Hybrid Maize ----------

agri:HybridMaize1 a agri:Maize ;
    a agri:CropVariety ;
    a gen:Hybrid ;
    rdfs:label "Hybrid Maize 1 (Makiry)"@en ;
    rdfs:label "Maïs Hybride 1 (Makiry)"@fr ;
    skos:definition "First generation hybrid maize developed for Malagasy conditions"@en ;
    gen:hasRegistrationDate "2005-11-30"^^xsd:date ;
    gen:hasPedigreeCode "MG-MZ-HYB-001" ;
    gen:isHybridOf agri:MaizeVarietyA ;
    gen:isHybridOf agri:MaizeVarietyB ;
    gen:developedIn <http://sws.geonames.org/1062894/> ;
    gen:bredBy <http://example.org/agents/FOFIFA> ;
    gen:hasGenerationNumber 1 ;
    agri:hasYieldPotential 8.5 ;
    .

