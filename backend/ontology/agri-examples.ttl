# ============================================================
# LIVESTOCK PEDIGREE EXAMPLES - Zebu Cattle
# ============================================================

# ---------- Foundation Zebu Bulls ----------

agri:ToamasinaBull-001 a agri:Bull ;
    a agri:Zebu ;
    a gen:Breed ;
    rdfs:label "Toamasina Bull 001"@en ;
    rdfs:label "Taureau Toamasina 001"@fr ;
    skos:definition "Foundation bull from Toamasina lineage"@en ;
    agri:hasBreed agri:MahafalyZebu ;
    agri:hasBirthDate "2010-03-15"^^xsd:date ;
    agri:hasWeight 450.0 ;
    agri:hasColor "Grey"@en ;
    agri:hasHealthStatus "Healthy"@en ;
    gen:hasPedigreeCode "MG-ZEB-TOAM-001" ;
    gen:bredBy <http://example.org/farmers/Ramanate> ;
    .

agri:AntsirabeCow-001 a agri:Cow ;
    a agri:Zebu ;
    a gen:Breed ;
    rdfs:label "Antsirabe Cow 001"@en ;
    rdfs:label "Vache Antsirabe 001"@fr ;
    skos:definition "Foundation cow from Antsirabe lineage"@en ;
    agri:hasBreed agri:BaraZebu ;
    agri:hasBirthDate "2009-07-20"^^xsd:date ;
    agri:hasWeight 380.0 ;
    agri:hasColor "White"@en ;
    agri:hasHealthStatus "Healthy"@en ;
    gen:hasPedigreeCode "MG-ZEB-ANTS-001" ;
    gen:bredBy <http://example.org/farmers/Rakoto> ;
    .

# ---------- First Generation Crossbred ----------

agri:MahazoRaha-Crossbred1 a agri:Cattle ;
    a agri:CrossbredCattle ;
    a gen:Hybrid ;
    rdfs:label "MahazoRaha Crossbred 1"@en ;
    rdfs:label "Croisé MahazoRaha 1"@fr ;
    skos:definition "First generation crossbred Zebu from Toamasina x Antsirabe"@en ;
    agri:hasBirthDate "2015-04-10"^^xsd:date ;
    agri:hasWeight 420.0 ;
    agri:hasColor "Grey-White"@en ;
    agri:hasHealthStatus "Healthy"@en ;
    gen:hasPedigreeCode "MG-ZEB-CB-001" ;
    gen:isHybridOf agri:ToamasinaBull-001 ;
    gen:isHybridOf agri:AntsirabeCow-001 ;
    gen:hasFather agri:ToamasinaBull-001 ;
    gen:hasMother agri:AntsirabeCow-001 ;
    gen:hasGenerationNumber 1 ;
    gen:bredBy <http://example.org/farmers/Ramanate> ;
    .

# ---------- Second Generation Crossbred ----------

agri:Fahavalon-002 a agri:Cattle ;
    a agri:CrossbredCattle ;
    a gen:Hybrid ;
    rdfs:label "Fahavalon Crossbred 2"@en ;
    rdfs:label "Croisé Fahavalon 2"@fr ;
    skos:definition "Second generation crossbred with improved traits"@en ;
    agri:hasBirthDate "2019-08-25"^^xsd:date ;
    agri:hasWeight 480.0 ;
    agri:hasColor "Grey"@en ;
    agri:hasHealthStatus "Healthy"@en ;
    gen:hasPedigreeCode "MG-ZEB-CB-002" ;
    gen:isHybridOf agri:MahazoRaha-Crossbred1 ;
    gen:isHybridOf agri:ToamasinaBull-001 ;
    gen:hasGenerationNumber 2 ;
    gen:bredBy <http://example.org/farmers/Rakoto> ;
    .

