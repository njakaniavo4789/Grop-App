<rdf:Description rdf:about="&agri;HighlandsRedSoil">
    <rdf:type rdf:resource="&agri;RedSoil"/>
    <rdf:type rdf:resource="&agri;LateriteSoil"/>
    <rdfs:label xml:lang="en">Highlands Red Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Rouge des Hautes Terres</rdfs:label>
    <rdfs:label xml:lang="mg">Tany maina an-tanety</rdfs:label>
    <agri:hasSoilPH rdf:resource="&agri;AcidicSoil"/>
    <agri:hasFertility rdf:resource="&agri;MediumFertility"/>
    <agri:hasDrainage rdf:resource="&agri;WellDrained"/>
    <agri:hasPHValue rdf:datatype="&xsd;decimal">5.5</agri:hasPHValue>
    <agri:hasNitrogenContent rdf:datatype="&xsd;decimal">0.15</agri:hasNitrogenContent>
    <agri:hasOrganicMatter rdf:datatype="&xsd;decimal">2.5</agri:hasOrganicMatter>
    <agri:suitableForCrop rdf:resource="&agri;Rice"/>
    <agri:suitableForCrop rdf:resource="&agri;Maize"/>
    <agri:suitableForCrop rdf:resource="&agri;Beans"/>
</rdf:Description>

<rdf:Description rdf:about="&agri;BemarahaAlluvialSoil">
    <rdf:type rdf:resource="&agri;AlluvialSoil"/>
    <rdfs:label xml:lang="en">Bemaraha Alluvial Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Alluvial de Bemaraha</rdfs:label>
    <rdfs:label xml:lang="mg">Tany rian-dranoka Bemaha</rdfs:label>
    <agri:hasSoilPH rdf:resource="&agri;NeutralSoil"/>
    <agri:hasFertility rdf:resource="&agri;HighFertility"/>
    <agri:hasDrainage rdf:resource="&agri;WellDrained"/>
    <agri:hasPHValue rdf:datatype="&xsd;decimal">6.8</agri:hasPHValue>
