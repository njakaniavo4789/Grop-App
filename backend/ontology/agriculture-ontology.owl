<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
    <!ENTITY foaf "http://xmlns.com/foaf/0.1/" >
    <!ENTITY agrovoc "http://aims.fao.org/aos/agrovoc/" >
    <!ENTITY agri "http://example.org/agri/" >
    <!ENTITY gen "http://example.org/gen/" >
    <!ENTITY geo "http://www.w3.org/2003/01/geo/wgs84_pos/" >
    <!ENTITY skos "http://www.w3.org/2004/02/skos/core#" >
    <!ENTITY dcterms "http://purl.org/dc/terms/" >
    <!ENTITY ontology "http://example.org/ontology/madagascar-agriculture" >
]>

<rdf:RDF 
    xmlns="&ontology;"
    xml:base="&ontology;"
    xmlns:owl="&owl;"
    xmlns:xsd="&xsd;"
    xmlns:rdfs="&rdfs;"
    xmlns:rdf="&rdf;"
    xmlns:foaf="&foaf;"
    xmlns:agrovoc="&agrovoc;"
    xmlns:agri="&agri;"
    xmlns:gen="&gen;"
    xmlns:geo="&geo;"
    xmlns:skos="&skos;"
    xmlns:dcterms="&dcterms;"
>

<!-- ============================================================ -->
<!-- ONTOLOGY HEADER -->
<!-- ============================================================ -->

<owl:Ontology rdf:about="http://example.org/ontology/madagascar-agriculture">
    <rdfs:label xml:lang="en">Madagascar Agriculture Ontology</rdfs:label>
    <rdfs:label xml:lang="fr">Ontologie de l'Agriculture de Madagascar</rdfs:label>
    <dcterms:title xml:lang="en">Madagascar Agriculture Ontology</dcterms:title>
    <dcterms:title xml:lang="fr">Ontologie de l'Agriculture de Madagascar</dcterms:title>
    <dcterms:creator>Ontology Engineering Team - FOFIFA &amp; Partner Institutions</dcterms:creator>
    <dcterms:created rdf:datatype="&xsd;date">2026-04-10</dcterms:created>
    <dcterms:description xml:lang="en">An OWL ontology for tracking crop varieties, agricultural practices, and soil types specifically designed for Madagascar agriculture.</dcterms:description>
    <dcterms:description xml:lang="fr">Une ontologie OWL pour le suivi des variétés de cultures, des pratiques agricoles et des types de sols, spécifiquement conçue pour l'agriculture malgache.</dcterms:description>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <rdfs:seeAlso rdf:resource="http://aims.fao.org/aos/agrovoc/"/>
</owl:Ontology>

<!-- ============================================================ -->
<!-- TOP LEVEL CLASSES -->
<!-- ============================================================ -->

<owl:Class rdf:about="&agri;Crop">
    <rdfs:label xml:lang="en">Crop</rdfs:label>
    <rdfs:label xml:lang="fr">Culture</rdfs:label>
    <rdfs:label xml:lang="mg">Famboly</rdfs:label>
    <skos:definition>Cultivated plants grown for agricultural production</skos:definition>
    <rdfs:subClassOf rdf:resource="&owl;Thing"/>
    <rdfs:subClassOf rdf:resource="&gen;Organism"/>
</owl:Class>

<owl:Class rdf:about="&agri;AgriculturalPractice">
    <rdfs:label xml:lang="en">Agricultural Practice</rdfs:label>
    <rdfs:label xml:lang="fr">Pratique Agricole</rdfs:label>
    <rdfs:label xml:lang="mg">Fampiharana Fambolena</rdfs:label>
    <rdfs:subClassOf rdf:resource="&owl;Thing"/>
</owl:Class>

<owl:Class rdf:about="&agri;Resource">
    <rdfs:label xml:lang="en">Agricultural Resource</rdfs:label>
    <rdfs:label xml:lang="fr">Ressource Agricole</rdfs:label>
    <rdfs:label xml:lang="mg">Harena Fambolena</rdfs:label>
    <rdfs:subClassOf rdf:resource="&owl;Thing"/>
</owl:Class>

<owl:Class rdf:about="&agri;AgriculturalOutput">
    <rdfs:label xml:lang="en">Agricultural Output</rdfs:label>
    <rdfs:label xml:lang="fr">Production Agricole</rdfs:label>
    <rdfs:label xml:lang="mg">Vokatra Fambolena</rdfs:label>
    <rdfs:subClassOf rdf:resource="&owl;Thing"/>
</owl:Class>

<!-- ============================================================ -->
<!-- GENEALOGICAL CLASSES -->
<!-- ============================================================ -->

<owl:Class rdf:about="&gen;Organism">
    <rdfs:label xml:lang="en">Organism</rdfs:label>
    <rdfs:label xml:lang="fr">Organisme</rdfs:label>
    <rdfs:subClassOf rdf:resource="&owl;Thing"/>
</owl:Class>

<owl:Class rdf:about="&gen;Hybrid">
    <rdfs:label xml:lang="en">Hybrid</rdfs:label>
    <rdfs:label xml:lang="fr">Hybride</rdfs:label>
    <rdfs:label xml:lang="mg">Ibrida</rdfs:label>
    <rdfs:subClassOf rdf:resource="&gen;Organism"/>
    <rdfs:subClassOf>
        <owl:Restriction>
            <owl:onProperty rdf:resource="&gen;hasParent"/>
            <owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">2</owl:minQualifiedCardinality>
            <owl:onClass rdf:resource="&gen;Organism"/>
        </owl:Restriction>
    </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="&gen;Cultivar">
    <rdfs:label xml:lang="en">Cultivar</rdfs:label>
    <rdfs:label xml:lang="fr">Cultivar</rdfs:label>
    <rdfs:subClassOf rdf:resource="&gen;Organism"/>
</owl:Class>

<owl:Class rdf:about="&gen;Variety">
    <rdfs:label xml:lang="en">Variety</rdfs:label>
    <rdfs:label xml:lang="fr">Variété</rdfs:label>
    <rdfs:label xml:lang="mg">Vary</rdfs:label>
    <rdfs:subClassOf rdf:resource="&gen;Cultivar"/>
</owl:Class>

<owl:Class rdf:about="&gen;Landrace">
    <rdfs:label xml:lang="en">Landrace</rdfs:label>
    <rdfs:label xml:lang="fr">Variété Traditionnelle</rdfs:label>
    <rdfs:label xml:lang="mg">Vary an-tanindrazana</rdfs:label>
    <skos:definition>Traditional crop variety adapted to local conditions over long periods</skos:definition>
    <rdfs:subClassOf rdf:resource="&gen;Variety"/>
</owl:Class>

<owl:Class rdf:about="&gen;ImprovedVariety">
    <rdfs:label xml:lang="en">Improved Variety</rdfs:label>
    <rdfs:label xml:lang="fr">Variété Améliorée</rdfs:label>
    <rdfs:label xml:lang="mg">Vary voatsara</rdfs:label>
    <skos:definition>Variety developed through breeding programs with improved characteristics</skos:definition>
    <rdfs:subClassOf rdf:resource="&gen;Variety"/>
</owl:Class>

