<!-- ============================================================ -->
<!-- SOIL TYPE SUBCLASSES -->
<!-- ============================================================ -->

<owl:Class rdf:about="&agri;ClaySoil">
    <rdfs:label xml:lang="en">Clay Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Argileux</rdfs:label>
    <rdfs:label xml:lang="mg">Tany tsy aminy</rdfs:label>
    <skos:definition>Heavy soil with high water retention, good for rice paddies</skos:definition>
    <rdfs:subClassOf rdf:resource="&agri;SoilType"/>
</owl:Class>

<owl:Class rdf:about="&agri;SandySoil">
    <rdfs:label xml:lang="en">Sandy Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Sableux</rdfs:label>
    <rdfs:label xml:lang="mg">Tany fasika</rdfs:label>
    <skos:definition>Light soil with good drainage, suitable for cassava and peanuts</skos:definition>
    <rdfs:subClassOf rdf:resource="&agri;SoilType"/>
</owl:Class>

<owl:Class rdf:about="&agri;LoamySoil">
    <rdfs:label xml:lang="en">Loamy Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Limoneux</rdfs:label>
    <rdfs:label xml:lang="mg">Tany fototra</rdfs:label>
    <skos:definition>Balanced soil with good fertility, suitable for most crops</skos:definition>
    <rdfs:subClassOf rdf:resource="&agri;SoilType"/>
</owl:Class>

<owl:Class rdf:about="&agri;SiltySoil">
    <rdfs:label xml:lang="en">Silty Soil</rdfs:label>
    <rdfs:label xml:lang="fr">Sol Limoneux Fin</rdfs:label>
    <rdfs:label xml:lang="mg">Tany tsin-dranomasina</rdfs:label>
    <skos:definition>Fine textured soil, good water retention</skos:definition>
    <rdfs:subClassOf rdf:resource="&agri;SoilType"/>
</owl:Class>

<owl:Class rdf:about="&agri;VolcanicSoil">
