caller_nid": "regionsidebar_regionsidebar", "callee": "split", "source_file": "src/components/dashboard/RegionSidebar.jsx", "source_location": "L46"}, {"caller_nid": "regionsidebar_regionsidebar", "callee": "max", "source_file": "src/components/dashboard/RegionSidebar.jsx", "source_location": "L47"}, {"caller_nid": "regionsidebar_regionsidebar", "callee": "(() => {\n              const W = 300, H = 44, data = node.sparkline;\n              const min = Math.min(...data), max = Math.max(...data);\n              const range = max - min || 1;\n              const pts = data.map((v, i) => {\n                const x = (i / (data.length - 1)) * W;\n                const y = H - ((v - min) / range) * (H - 6) - 3;\n                return `${x.toFixed(1)},${y.toFixed(1)}`;\n              }).join(' ');\n              const [fx] = pts.split(' ')[0].split(',');\n              const [lx] = pts.split(' ').slice(-1)[0].split(',');\n              return (\n                <>\n                  <polygon points={`${fx},${H} ${pts} ${lx},${H}`} fill={`url(#sg-${node.id})`} />\n                  <polyline points={pts} fill=\"none\" stroke={accent} strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\" />\n                  {data.map((v, i) => {\n                    const x = (i / (data.length - 1)) * W;\n                    const y = H - ((v - min) / range) * (H - 6) - 3;\n                    return <circle key={i} cx={x} cy={y} r=\"2.5\" fill={accent} opacity={i === data.length - 1 ? 1 : 0.4} />;\n                  })}\n                </>\n              );\n            })", "source_file": "src/components/dashboard/RegionSidebar.jsx", "source_location": "L164"}, {"caller_nid": "regionsidebar_regionsidebar", "callee": "map", "source_file": "src/components/dashboard/RegionSidebar.jsx", "source_location": "L198"}, {"caller_nid": "regionsidebar_regionsidebar", "callee": "map", "source_file": "src/components/dashboard/RegionSidebar.jsx", "source_location": "L216"}, {"caller_nid"